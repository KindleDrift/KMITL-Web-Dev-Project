@model WebDevProject.Models.OnboardingViewModel

@{
    ViewData["Title"] = "Onboarding";
}

@section Styles {
    <link rel="stylesheet" href="~/css/onboarding.css" asp-append-version="true" />
}

<div class="login-container">
    <h1 class="header-1">Onboarding</h1>
    <div class="card" id="signin-container">
        <form id="signin-form" asp-controller="Account" asp-action="Onboarding" method="post" enctype="multipart/form-data">
            <fieldset>
                <legend>Tell us about yourself</legend>

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-input">
                    <label asp-for="ProfileImage">Profile Picture:</label>
                    <img id="profile-pic-preview" src="~/images/default-profile.png" alt="Profile Picture Preview" class="profile-pic-preview" />
                    <input asp-for="ProfileImage" type="file" accept="image/*" />
                    <span asp-validation-for="ProfileImage" class="text-danger"></span>
                </div>

                <div class="form-input">
                    <label asp-for="DateOfBirth">Birthdate:</label>
                    <input asp-for="DateOfBirth" type="date"/>
                    <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                </div>

                <div class="form-input">
                    <label asp-for="UserGender">Gender:</label>
                    <div class="gender-options">
                        <label class="gender-option">
                            <input asp-for="UserGender" type="radio" value="0" />
                            <span class="material-symbols-outlined">male</span>
                            <span>Male</span>
                        </label>
                        <label class="gender-option">
                            <input asp-for="UserGender" type="radio" value="1" />
                            <span class="material-symbols-outlined">female</span>
                            <span>Female</span>
                        </label>
                        <label class="gender-option">
                            <input asp-for="UserGender" type="radio" value="2" />
                            <span class="material-symbols-outlined">transgender</span>
                            <span>Other</span>
                        </label>
                    </div>
                    <span asp-validation-for="UserGender" class="text-danger"></span>
                </div>

                <div class="form-input">
                    <label asp-for="Bio">Bio:</label>
                    <textarea asp-for="Bio" rows="4" placeholder="Tell us about yourself..."></textarea>
                    <span asp-validation-for="Bio" class="text-danger"></span>
                </div>

                <input asp-for="SkipOnboarding" type="hidden" value="false" />

                <div class="form-actions">
                    <button class="large-button" type="submit">Complete Onboarding</button>
                </div>
            </fieldset>
        </form>
        <p>Don't want to complete onboarding? <button type="button" id="skip-onboarding-btn" class="link-button">Skip for now</button></p>
    </div>
</div>

@section Scripts {
    <script src="~/js/onboarding.js" asp-append-version="true"></script>
}