@model List<Board>

@{
    ViewData["Title"] = "Manage Boards";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}

<div class="main-container">
    <h1 class="header-1">Manage Boards</h1>
    
    <div class="table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Location</th>
                    <th>Event Date</th>
                    <th>Deadline</th>
                    <th>Max Participants</th>
                    <th>Status</th>
                    <th>Created At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var board in Model)
                {
                    <tr>
                        <td>@board.Id</td>
                        <td>@board.Title</td>
                        <td>@board.Author?.DisplayName</td>
                        <td>@board.Location</td>
                        <td><span data-utc-datetime="@board.EventDate.ToString("yyyy-MM-ddTHH:mm:ss")" data-utc-format="datetime">@board.EventDate.ToString("yyyy-MM-dd HH:mm")</span></td>
                        <td><span data-utc-datetime="@board.Deadline.ToString("yyyy-MM-ddTHH:mm:ss")" data-utc-format="datetime">@board.Deadline.ToString("yyyy-MM-dd HH:mm")</span></td>
                        <td>@board.MaxParticipants</td>
                        <td>
                            @switch (board.CurrentStatus)
                            {
                                case BoardStatus.Open:
                                    <span class="status-open">Open</span>
                                    break;
                                case BoardStatus.Full:
                                    <span class="status-full">Full</span>
                                    break;
                                case BoardStatus.Closed:
                                    <span class="status-closed">Closed</span>
                                    break;
                                case BoardStatus.Cancelled:
                                    <span class="status-cancelled">Cancelled</span>
                                    break;
                                case BoardStatus.Archived:
                                    <span class="status-archived">Archived</span>
                                    break;
                            }
                        </td>
                        <td><span data-utc-datetime="@board.CreatedAt.ToString("yyyy-MM-ddTHH:mm:ss")" data-utc-format="datetime">@board.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span></td>
                        <td>
                            <a asp-controller="Admin" asp-action="EditBoard" asp-route-id="@board.Id" class="btn btn-sm btn-primary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="action-buttons">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
