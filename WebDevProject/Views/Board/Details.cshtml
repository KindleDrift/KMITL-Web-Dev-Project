@using WebDevProject.Models;
@model WebDevProject.Models.BoardDetailsViewModel

@{
    ViewData["Title"] = Model.Board.Title;
}

@section Styles {
    <link rel="stylesheet" href="~/css/board.css" asp-append-version="true" />
}

<div class="main-container">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error">@TempData["Error"]</div>
    }

    <div class="card">
        <div class="board-details-header">
            <h1>@Model.Board.Title</h1>
            @if (Model.IsAuthor)
            {
                <div style="display: flex; gap: 10px;">
                    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Board.Id">Edit Board</a>
                    @if (Model.Board.CurrentStatus != BoardStatus.Archived && Model.Board.CurrentStatus != BoardStatus.Cancelled)
                    {
                        <form asp-action="Cancel" asp-route-id="@Model.Board.Id" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to cancel this board? This will remove all participants, deny all pending applications, and notify everyone. This action cannot be undone.');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">Cancel Board</button>
                        </form>
                    }
                    @if (Model.Board.CurrentStatus != BoardStatus.Archived && (Model.Board.EventDate <= DateTimeOffset.UtcNow.UtcDateTime || Model.Board.CurrentStatus == BoardStatus.Cancelled))
                    {
                        <form asp-action="Archive" asp-route-id="@Model.Board.Id" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to archive this board? This action will hide the board from active listings.');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-warning">Archive Board</button>
                        </form>
                    }
                </div>
            }
        </div>

        @{
            var isOpenPastDeadline = Model.Board.CurrentStatus == WebDevProject.Models.BoardStatus.Open && Model.Board.Deadline <= DateTimeOffset.UtcNow.UtcDateTime;
            var visibleParticipants = Model.Participants.Where(p => p.UserId != Model.Board.AuthorId).ToList();
            var visibleOccupiedSlots = visibleParticipants.Count + Model.ExternalParticipants.Count;
            var statusClass = Model.Board.CurrentStatus switch
            {
                WebDevProject.Models.BoardStatus.Open => isOpenPastDeadline ? "status-closed" : "status-open",
                WebDevProject.Models.BoardStatus.Full => "status-full",
                WebDevProject.Models.BoardStatus.Closed => "status-closed",
                WebDevProject.Models.BoardStatus.Cancelled => "status-cancelled",
                WebDevProject.Models.BoardStatus.Archived => "status-archived",
                _ => "status-open"
            };
            var displayStatus = isOpenPastDeadline ? "Open (Deadline Passed)" : Model.Board.CurrentStatus.ToString();
        }

        <div class="board-details-content">
            @if (!string.IsNullOrWhiteSpace(Model.Board.ImageUrl))
            {
                <div class="board-details-image">
                    <img src="@Model.Board.ImageUrl" 
                         alt="@Model.Board.Title"
                         onerror="this.src='/images/default-board.png'" />
                </div>
            }

            <div class="board-info-section">
                <h3>Board Information</h3>
                <div class="board-meta-grid">
                    <div><strong>Status:</strong> <span class="status-badge @statusClass">@displayStatus</span></div>
                    <div><strong>Event Date:</strong> <span data-utc-datetime="@Model.Board.EventDate.ToString("yyyy-MM-ddTHH:mm:ss")" data-utc-format="datetime">@Model.Board.EventDate.ToString("dd MMM yyyy, HH:mm")</span></div>
                    <div><strong>Location:</strong> @Model.Board.Location</div>
                    <div><strong>Join Deadline:</strong> <span data-utc-datetime="@Model.Board.Deadline.ToString("yyyy-MM-ddTHH:mm:ss")" data-utc-format="datetime">@Model.Board.Deadline.ToString("dd MMM yyyy, HH:mm")</span></div>
                    <div><strong>Participants:</strong> @visibleOccupiedSlots / @Model.Board.MaxParticipants</div>
                    <div><strong>Join System:</strong> @(Model.Board.JoinPolicy == BoardJoinPolicy.FirstComeFirstServe ? "First-Come-First-Serve" : "Application System")</div>
                    <div><strong>Author:</strong> 
                        <a href="/Profile/u/@Uri.EscapeDataString(Model.Board.Author?.DisplayName ?? "Unknown")" style="display: inline-flex; align-items: center; gap: 5px; text-decoration: none; color: inherit;">
                            <img src="@(Model.Board.Author?.ProfilePictureUrl ?? Url.Content("~/images/default-profile.png"))" alt="@(Model.Board.Author?.DisplayName ?? "Author")" class="small-avatar" />
                            <span>@(Model.Board.Author?.DisplayName ?? "Unknown")</span>
                        </a>
                    </div>
                </div>

                @if (Model.Board.Tags.Any())
                {
                    <div class="tags-section">
                        <strong>Tags:</strong>
                        @foreach (var tag in Model.Board.Tags)
                        {
                            <span class="tag">@tag.Name</span>
                        }
                    </div>
                }

                <div class="description-section">
                    <h3>Description</h3>
                    <p>@Model.Board.Description</p>
                </div>
            </div>

            @if (!Model.IsAuthor && User.Identity?.IsAuthenticated == true)
            {
                <div class="application-section">
                    @if (Model.UserApplicationStatus == WebDevProject.Models.ApplicationStatus.NotApplied)
                    {
                        @if (Model.Board.CurrentStatus == WebDevProject.Models.BoardStatus.Open && Model.Board.Deadline > DateTimeOffset.UtcNow.UtcDateTime)
                        {
                            <form asp-action="Apply" asp-route-id="@Model.Board.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-info">@(Model.Board.JoinPolicy == BoardJoinPolicy.FirstComeFirstServe ? "Join Now" : "Apply to Join")</button>
                            </form>
                        }
                        else
                        {
                            <p class="status-message">Applications are currently closed.</p>
                        }
                    }
                    else if (Model.UserApplicationStatus == WebDevProject.Models.ApplicationStatus.Pending)
                    {
                        <p class="status-message status-pending">Your application is pending approval.</p>
                        <form asp-action="CancelMyApplication" asp-route-id="@Model.Board.Id" method="post" style="margin-top: 8px;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-secondary">Cancel My Application</button>
                        </form>
                    }
                    else if (Model.UserApplicationStatus == WebDevProject.Models.ApplicationStatus.Approved)
                    {
                        <p class="status-message status-approved">You are a participant in this board.</p>
                        <form asp-action="CancelMyApplication" asp-route-id="@Model.Board.Id" method="post" style="margin-top: 8px;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-secondary">Leave Board</button>
                        </form>
                    }
                    else if (Model.UserApplicationStatus == WebDevProject.Models.ApplicationStatus.Denied)
                    {
                        <p class="status-message status-denied">Your application was denied. You cannot apply to this board again.</p>
                    }
                </div>
            }

            <div class="status-sections-container">
                <div class="participants-section status-section-column">
                    <h3>Participants (@visibleOccupiedSlots / @Model.Board.MaxParticipants)</h3>
                    @if (visibleParticipants.Any())
                    {
                        <div class="user-list">
                            @foreach (var participant in visibleParticipants)
                            {
                                <div class="user-item">
                                    <a href="/Profile/u/@Uri.EscapeDataString(participant.User?.DisplayName ?? "Unknown")" style="display: flex; align-items: center; gap: 10px; text-decoration: none; color: inherit; flex: 1;">
                                        <img src="@(participant.User?.ProfilePictureUrl ?? Url.Content("~/images/default-profile.png"))" alt="@(participant.User?.DisplayName ?? "Participant")" class="user-avatar" />
                                        <div class="user-info">
                                            <div class="user-name">@(participant.User?.DisplayName ?? "Unknown")</div>
                                            <div class="user-meta">Joined: <span data-utc-datetime="@participant.JoinedAt.ToString("yyyy-MM-ddTHH:mm:ss")" data-utc-format="datetime">@participant.JoinedAt.ToString("dd MMM yyyy, HH:mm")</span></div>
                                        </div>
                                    </a>
                                    @if (Model.IsAuthor && Model.Board.CurrentStatus != BoardStatus.Cancelled && Model.Board.CurrentStatus != BoardStatus.Archived)
                                    {
                                        <div class="user-actions">
                                            <form asp-action="DenyParticipant" asp-route-boardId="@Model.Board.Id" asp-route-participantId="@participant.UserId" method="post" class="inline-form">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-danger btn-sm">Deny</button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p>No on-website participants yet.</p>
                    }

                    @if (Model.ExternalParticipants.Any())
                    {
                        <h4>External Participants (@Model.ExternalParticipants.Count)</h4>
                        <div class="user-list">
                            @foreach (var external in Model.ExternalParticipants)
                            {
                                <div class="user-item">
                                    <div class="user-info">
                                        <div class="user-name">@external.Name</div>
                                        <div class="user-meta">Added: <span data-utc-datetime="@external.AddedAt.ToString("yyyy-MM-ddTHH:mm:ss")" data-utc-format="date">@external.AddedAt.ToString("dd MMM yyyy")</span></div>
                                        @if (!string.IsNullOrWhiteSpace(external.Note))
                                        {
                                            <div class="user-meta">@external.Note</div>
                                        }
                                    </div>
                                    @if (Model.IsAuthor && Model.Board.CurrentStatus != BoardStatus.Cancelled && Model.Board.CurrentStatus != BoardStatus.Archived)
                                    {
                                        <div class="user-actions">
                                            <form asp-action="RemoveExternalParticipant" asp-route-boardId="@Model.Board.Id" asp-route-externalParticipantId="@external.Id" method="post" class="inline-form">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-secondary btn-sm">Remove</button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                @if (Model.IsAuthor)
                {
                    @if (Model.Board.CurrentStatus != BoardStatus.Cancelled && Model.Board.CurrentStatus != BoardStatus.Archived)
                    {
                        <div class="applicants-section status-section-column">
                            <h3>Add External Participant</h3>
                            <form asp-action="AddExternalParticipant" asp-route-boardId="@Model.Board.Id" method="post">
                                @Html.AntiForgeryToken()
                                <div class="form-group">
                                    <input type="text" name="externalName" placeholder="Name" maxlength="120" required />
                                </div>
                                <div class="form-group">
                                    <input type="text" name="externalNote" placeholder="Optional note (e.g. contact)" maxlength="200" />
                                </div>
                                <button type="submit" class="btn btn-success">Add External Participant</button>
                            </form>
                        </div>
                    }

                    @if (Model.Board.JoinPolicy == BoardJoinPolicy.Application && Model.Board.CurrentStatus != BoardStatus.Cancelled && Model.Board.CurrentStatus != BoardStatus.Archived)
                    {
                        <div class="applicants-section status-section-column">
                            <h3>Pending Applications (@Model.Applicants.Count)</h3>
                            @if (Model.Applicants.Any())
                            {
                                <div class="user-list">
                                    @foreach (var applicant in Model.Applicants)
                                    {
                                        <div class="user-item applicant-item">
                                            <a href="/Profile/u/@Uri.EscapeDataString(applicant.User?.DisplayName ?? "Unknown")" style="display: flex; align-items: center; gap: 10px; text-decoration: none; color: inherit; flex: 1;">
                                                <img src="@(applicant.User?.ProfilePictureUrl ?? Url.Content("~/images/default-profile.png"))" alt="@(applicant.User?.DisplayName ?? "Applicant")" class="user-avatar" />
                                                <div class="user-info">
                                                    <div class="user-name">@(applicant.User?.DisplayName ?? "Unknown")</div>
                                                    <div class="user-meta">Applied: <span data-utc-datetime="@applicant.AppliedAt.ToString("yyyy-MM-ddTHH:mm:ss")" data-utc-format="datetime">@applicant.AppliedAt.ToString("dd MMM yyyy, HH:mm")</span></div>
                                                </div>
                                            </a>
                                            <div class="user-actions">
                                                <form asp-action="ApproveApplicant" asp-route-boardId="@Model.Board.Id" asp-route-applicantId="@applicant.UserId" method="post" class="inline-form">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-success btn-sm">Approve</button>
                                                </form>
                                                <form asp-action="DenyApplicant" asp-route-boardId="@Model.Board.Id" asp-route-applicantId="@applicant.UserId" method="post" class="inline-form">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-danger btn-sm">Deny</button>
                                                </form>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p>No pending applications.</p>
                            }
                        </div>
                    }

                    @if (Model.Board.CurrentStatus != BoardStatus.Cancelled && Model.Board.CurrentStatus != BoardStatus.Archived)
                    {
                        <div class="denied-section status-section-column">
                            <h3>Denied Users (@Model.DeniedUsers.Count)</h3>
                            @if (Model.DeniedUsers.Any())
                            {
                                <div class="user-list">
                                    @foreach (var denied in Model.DeniedUsers)
                                    {
                                        <div class="user-item">
                                            <a href="/Profile/u/@Uri.EscapeDataString(denied.User?.DisplayName ?? "Unknown")" style="display: flex; align-items: center; gap: 10px; text-decoration: none; color: inherit; flex: 1;">
                                                <img src="@(denied.User?.ProfilePictureUrl ?? Url.Content("~/images/default-profile.png"))" alt="@(denied.User?.DisplayName ?? "Denied User")" class="user-avatar" />
                                                <div class="user-info">
                                                    <div class="user-name">@(denied.User?.DisplayName ?? "Unknown")</div>
                                                    <div class="user-meta">Denied: <span data-utc-datetime="@denied.DeniedAt.ToString("yyyy-MM-ddTHH:mm:ss")" data-utc-format="datetime">@denied.DeniedAt.ToString("dd MMM yyyy, HH:mm")</span></div>
                                                </div>
                                            </a>
                                            <div class="user-actions">
                                                <form asp-action="RemoveDenial" asp-route-boardId="@Model.Board.Id" asp-route-deniedUserId="@denied.UserId" method="post" class="inline-form">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-secondary btn-sm">Remove Denial</button>
                                                </form>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p>No denied users.</p>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <div class="back-link">
            <a asp-action="Index">← Back to Dashboard</a>
        </div>
    </div>
</div>
