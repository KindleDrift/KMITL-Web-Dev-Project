@model BoardCreateViewModel

@{
    ViewData["Title"] = "Edit Board";
    var boardId = (int)ViewBag.BoardId;
    var currentImageUrl = ViewBag.CurrentImageUrl as string;
    var isCancelledOrArchived = (bool?)ViewBag.IsCancelledOrArchived ?? false;
}

@section Styles {
    <link rel="stylesheet" href="~/css/board.css" asp-append-version="true" />
}

<div class="main-container">
    <h1>Edit Board</h1>

    @if (isCancelledOrArchived)
    {
        <div class="alert alert-warning" style="margin-bottom: 20px;">
            This board is @(Model.CurrentStatus == BoardStatus.Cancelled ? "cancelled" : "archived"). Only the status can be changed. All other fields are disabled.
        </div>
    }

    <div class="card">
        <form id="boardForm" method="post" asp-controller="Board" asp-action="Edit" asp-route-id="@boardId" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="title">Title *</label>
                <input type="text" id="title" asp-for="Title" placeholder="What is your board about?" required disabled="@isCancelledOrArchived">
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="description">Description *</label>
                <textarea id="description" asp-for="Description" rows="4" placeholder="Tell us more about your board..." required disabled="@isCancelledOrArchived"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="boardImage">Board Image</label>
                @if (!string.IsNullOrWhiteSpace(currentImageUrl))
                {
                    <div style="margin-bottom: 12px;">
                        <img src="@currentImageUrl" alt="Current board image" style="max-width: 260px; max-height: 180px; border-radius: 8px; object-fit: cover;" />
                    </div>
                }
                <input type="file" id="boardImage" asp-for="BoardImage" accept="image/*" disabled="@isCancelledOrArchived">
                <span asp-validation-for="BoardImage" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="location">Location *</label>
                <input type="text" id="location" asp-for="Location" placeholder="Where will this take place?" required disabled="@isCancelledOrArchived">
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="eventDate">Event Date *</label>
                    <input type="datetime-local" id="eventDate" asp-for="EventDate" required disabled="@isCancelledOrArchived">
                    <span asp-validation-for="EventDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="deadline">Registration Deadline *</label>
                    <input type="datetime-local" id="deadline" asp-for="Deadline" required disabled="@isCancelledOrArchived">
                    <span asp-validation-for="Deadline" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label for="maxParticipants">Maximum Participants *</label>
                <input type="number" id="maxParticipants" asp-for="MaxParticipants" min="1" max="1000" required disabled="@isCancelledOrArchived">
                <span asp-validation-for="MaxParticipants" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="currentStatus">Board Status *</label>
                <select id="currentStatus" asp-for="CurrentStatus" class="form-control" required>
                    <option value="Open">Open</option>
                    <option value="Full">Full</option>
                    <option value="Closed">Closed</option>
                </select>
                <span asp-validation-for="CurrentStatus" class="text-danger"></span>
                <small style="display: block; margin-top: 4px; color: #666; font-size: 0.9em;">
                    @if (isCancelledOrArchived)
                    {
                        <text>Change the status to reopen the board for full editing capabilities.</text>
                    }
                    else
                    {
                        <text>Note: Status may be automatically updated based on capacity and group management settings.
                        Changing Join Policy or Group Management may affect status. To cancel or archive this board, use the respective buttons on the details page.</text>
                    }
                </small>
            </div>

            <div class="form-group">
                <label>Join Policy *</label>
                <div class="radio-group">
                    <div class="radio-option">
                        <input type="radio" id="joinApplication" name="JoinPolicyOption" value="application" @(Model.JoinPolicyOption == "application" ? "checked" : "") required disabled="@isCancelledOrArchived">
                        <label for="joinApplication">Application (author reviews applicants)</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="joinFcfs" name="JoinPolicyOption" value="fcfs" @(Model.JoinPolicyOption == "fcfs" ? "checked" : "") disabled="@isCancelledOrArchived">
                        <label for="joinFcfs">First Come First Serve (auto-join)</label>
                    </div>
                </div>
                <span asp-validation-for="JoinPolicyOption" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Tags</label>
                <div class="tag-input-group">
                    <input type="text" id="tagInput" placeholder="Enter a tag..." disabled="@isCancelledOrArchived">
                    <button type="button" id="addTagButton" class="btn btn-light" disabled="@isCancelledOrArchived">Add Tag</button>
                </div>
                <div id="tagContainer">
                    @foreach (var tag in Model.Tags)
                    {
                        <span class="tag" data-tag="@tag">@tag</span>
                    }
                </div>
            </div>

            <div class="form-group">
                <label>Group Management *</label>
                <div class="radio-group">
                    <div class="radio-option">
                        <input type="radio" id="closeOnFull" name="GroupManagementOption" value="closeOnFull" @(Model.GroupManagementOption == "closeOnFull" ? "checked" : "") required disabled="@isCancelledOrArchived">
                        <label for="closeOnFull">Close on full (board status becomes Full, no more joins)</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="allowOverbooking" name="GroupManagementOption" value="allowOverbooking" @(Model.GroupManagementOption == "allowOverbooking" ? "checked" : "") disabled="@isCancelledOrArchived">
                        <label for="allowOverbooking">Allow overbooking (author can approve beyond max capacity)</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="keepOpenWhenFull" name="GroupManagementOption" value="keepOpenWhenFull" @(Model.GroupManagementOption == "keepOpenWhenFull" ? "checked" : "") disabled="@isCancelledOrArchived">
                        <label for="keepOpenWhenFull">Keep open when full (stay Open, but still enforce capacity)</label>
                    </div>
                </div>
                <span asp-validation-for="GroupManagementOption" class="text-danger"></span>
            </div>

            <div class="form-input">
                <div class="single-checkbox-input">
                    <input type="checkbox" id="notifyOnFull" asp-for="NotifyAuthorOnFull" disabled="@isCancelledOrArchived">
                    <label for="notifyOnFull">Notify me when the group is full</label>
                </div>
            </div>

            <div style="display:flex; gap:10px; margin-top: 20px;">
                <button type="submit" class="btn btn-accent" style="flex: 1;">@(isCancelledOrArchived ? "Update Status" : "Save Changes")</button>
                <a asp-controller="Board" asp-action="Details" asp-route-id="@boardId" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/boardcreate.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}}