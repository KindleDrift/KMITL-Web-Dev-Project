@{
    ViewData["Title"] = "About";
}

@section Styles {
    <link rel="stylesheet" href="~/css/about.css" asp-append-version="true" />
}

<div class="main-container about-container">
    <section class="about-header">
        <h1>About KMITL Web Dev Project</h1>
        <p class="about-subtitle">An ASP.NET Core MVC Web Application Project as a part of Web Application Development coursework at KMITL</p>
    </section>

    <section class="project-goals">
        <h2><span class="material-symbols-outlined">rocket_launch</span> Project Goals</h2>
        <div class="goals-grid">
            <div class="goal-card">
                <span class="material-symbols-outlined goal-icon">forum</span>
                <h3>Web Board Application</h3>
                <p>Create a simple and intuitive web board platform for discussions and community engagement.</p>
            </div>
            <div class="goal-card">
                <span class="material-symbols-outlined goal-icon">lock</span>
                <h3>User Authentication</h3>
                <p>Implement secure user sign-up and sign-in functionality with modern authentication practices.</p>
            </div>
            <div class="goal-card">
                <span class="material-symbols-outlined goal-icon">code</span>
                <h3>ASP.NET Core MVC</h3>
                <p>Build a robust web application using ASP.NET Core MVC architecture and .NET 10.0 SDK.</p>
            </div>
            <div class="goal-card">
                <span class="material-symbols-outlined goal-icon">school</span>
                <h3>Learning Experience</h3>
                <p>Apply web development concepts and best practices learned in the coursework at KMITL.</p>
            </div>
        </div>
    </section>

    <section class="tech-stack">
        <h2><span class="material-symbols-outlined">deployed_code</span> Tech Stack</h2>
        <div class="tech-list">
            <div class="tech-item">
                <span class="material-symbols-outlined">language</span>
                <span>ASP.NET Core MVC</span>
            </div>
            <div class="tech-item">
                <span class="material-symbols-outlined">terminal</span>
                <span>.NET 10.0 SDK</span>
            </div>
        </div>
    </section>

