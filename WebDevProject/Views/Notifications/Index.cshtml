@model List<Notification>
@using WebDevProject.Services
@inject NotificationFormattingService FormattingService

@{
    ViewData["Title"] = "Notifications";
    int unreadCount = (int?)ViewData["UnreadCount"] ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />
}

<div class="main-container">
    <div class="notifications-page">
        <div class="notifications-header">
            <h2>Notifications</h2>
            <div class="notifications-header-actions">
                <span class="unread-badge">
                    <span id="unread-count">@unreadCount</span> Unread
                </span>
                @if (unreadCount > 0)
                {
                    <button class="btn-mark-all" onclick="markAllAsRead()">
                        Mark all as read
                    </button>
                }
                @if (Model.Any())
                {
                    <button class="btn-delete-all" onclick="deleteAllNotifications()">
                        Delete all
                    </button>
                }
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="no-notifications">
                <p>You have no notifications yet.</p>
            </div>
        }
        else
        {
            <div class="notifications-list">
                @foreach (var notification in Model)
                {
                    <div class="notification-item @(!notification.IsRead ? "unread" : "")" id="notification-@notification.Id">
                        <div class="notification-content">
                            <div class="notification-header">
                                <h3 class="notification-title">@notification.Title</h3>
                                @if (!notification.IsRead)
                                {
                                    <span class="badge-new">New</span>
                                }
                            </div>
                            <div class="notification-type-badge">
                                <span class="badge @FormattingService.GetNotificationBadgeClass(notification.Type)">
                                    @FormattingService.GetNotificationTypeDisplay(notification.Type)
                                </span>
                            </div>
                            <p class="notification-description">
                                @Html.Raw(FormattingService.FormatNotificationDescription(
                                    notification,
                                    displayName => Url.Action("Details", "Profile", new { displayName = displayName }) ?? "#",
                                    boardId => Url.Action("Details", "Board", new { id = boardId }) ?? "#"
                                ))
                            </p>
                            <small class="notification-time">
                                @FormattingService.GetTimeAgoString(notification.CreatedDate)
                            </small>
                        </div>
                        <div class="notification-actions">
                            @if (!notification.IsRead)
                            {
                                <button class="btn-action btn-mark-read" onclick="markAsRead(@notification.Id)" title="Mark as read">
                                    <span class="material-symbols-outlined">check_circle</span>
                                    <span class="btn-text">Mark Read</span>
                                </button>
                            }
                            <button class="btn-action btn-delete" onclick="deleteNotification(@notification.Id)" title="Delete">
                                <span class="material-symbols-outlined">close</span>
                                <span class="btn-text">Delete</span>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/notifications.js" asp-append-version="true"></script>
}
