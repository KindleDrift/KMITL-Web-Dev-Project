@model WebDevProject.Models.EditProfileViewModel

@{
    ViewData["Title"] = "Edit Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/editprofile.css" asp-append-version="true" />
}

<div class="main-container">
    <form id="editprofile-form" asp-action="Edit" method="post" enctype="multipart/form-data"> 
        @Html.AntiForgeryToken()
        
        <div class="edit-picture">
            <img class="profile-picture" id="preview" src="@(Model.CurrentProfilePictureUrl ?? "/images/default-profile.png")" alt="Profile Picture">
            <input asp-for="ProfileImage" type="file" id="imageInput" accept="image/*" hidden>
            <button id="changePicBtn" type="button" class="btn btn-secondary">Change Picture</button>
            <span asp-validation-for="ProfileImage" class="text-danger"></span>
        </div>
        
        <div class="card" id="profile-data">
            <div class="form-group">
                <label asp-for="UserName">Username</label>
                <input asp-for="UserName" id="usernameInput" required>
                <span asp-validation-for="UserName" class="text-danger"></span>
                <span id="nameError" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="UserGender">Gender</label>
                <div class="gender-options">
                    <label>
                        <input asp-for="UserGender" type="radio" id="male" value="0" />
                        <span class="material-symbols-outlined">male</span>
                        <span>Male</span>
                    </label>
                    <label>
                        <input asp-for="UserGender" type="radio" id="female" value="1" />
                        <span class="material-symbols-outlined">female</span>
                        <span>Female</span>
                    </label>
                    <label>
                        <input asp-for="UserGender" type="radio" id="other" value="2" />
                        <span class="material-symbols-outlined">transgender</span>
                        <span>Other</span>
                    </label>
                </div>
                <span asp-validation-for="UserGender" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="DateOfBirth">Birth Date</label>
                <input asp-for="DateOfBirth" type="date" id="birthdateInput"/>
                <span asp-validation-for="DateOfBirth" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Bio">Bio</label>
                <textarea asp-for="Bio" id="bioInput" rows="4" placeholder="Tell us about yourself..."></textarea>
                <span asp-validation-for="Bio" class="text-danger"></span>
            </div>
            
            <div class="button-group">
                <button type="submit" class="large-button">Save Changes</button>
                <a asp-action="ChangePassword" class="large-button btn-secondary">Change Password</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/editprofile.js" asp-append-version="true"></script>
}