@model WebDevProject.Models.Users

@{
    ViewData["Title"] = "Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}

<div class="profile">
    @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
    {
        <img class="profile-picture" id="picture" src="@Model.ProfilePictureUrl" alt="picture">
    }
    else
    {
        <img class="profile-picture" id="picture" src="~/images/default-profile.png" alt="picture">
    }

    <div class="profile-data">
        <a class="profile-link" href="@Url.Action("Edit", "Profile")">edit profile</a>

        <div class="data-menu">
            <div class="row">
                <span class="label">username :</span>
                @if (!string.IsNullOrWhiteSpace(Model.DisplayName))
                {
                    <span>@Model.DisplayName</span>
                }
                else
                {
                    <span>-</span>
                }
            </div>

            <div class="row">
                <span class="label">email :</span>
                @if (!string.IsNullOrWhiteSpace(Model.Email))
                {
                    <span>@Model.Email</span>
                }
                else
                {
                    <span class="text-muted">Not provided</span>
                }
            </div>

            <div class="row">
                <span class="label">birth date :</span>
                @if (Model.DateOfBirth.HasValue)
                {
                    <span>@Model.DateOfBirth.Value.ToString("MMMM dd, yyyy")</span>
                }
                else
                {
                    <span class="text-muted">Not provided</span>
                }
            </div>

            <div class="row">
                <span class="label">gender :</span>
                @if (Model.UserGender.HasValue)
                {
                    <span>@Model.UserGender</span>
                }
                else
                {
                    <span class="text-muted">Not provided</span>
                }
            </div>

            <div class="row">
                <span class="label">member since :</span>
                <span>@Model.CreatedAt.ToString("MMMM dd, yyyy")</span>
            </div>
        </div>

        <a class="profile-link" href="@Url.Action("ChangePassword", "Account")">reset password</a>

        <form asp-action="SignOut" asp-controller="Account" method="post" style="display: inline;">
            <button type="submit" class="profile-link" style="border: none; background: none; padding: 0;">sign out</button>
        </form>
    </div>
</div>
