@model WebDevProject.Models.UserProfileViewModel

@{
    ViewData["Title"] = Model.DisplayName + "'s Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}

<div class="main-container" id="profile">
    <img class="profile-picture" id="picture" src="@(Model.ProfilePictureUrl ?? "/images/default-profile.png")" alt="Profile Picture">
    <div class="card" id="profile-data">

        <!-- show for yourself -->
        @if (Model.IsOwnProfile)
        {
            <button> class="large-button" href="@Url.Action("Edit", "Profile")">Edit Profile</button>
        }

        <!-- show for everyone -->
        <div class="data-menu">
            <div class="row">
                <span class="label">Username :</span>
                <span>@Model.DisplayName</span>
            </div>

            <!-- show for yourself -->
            @if (Model.IsOwnProfile)
            {
                <div class="row">
                    <span class="label">Email :</span>
                    <span>@Model.Email</span>
                </div>

                <div class="row">
                    <span class="label">Birth Date :</span>
                    @if (Model.DateOfBirth.HasValue)
                    {
                        <span>@Model.DateOfBirth.Value.ToString("MMMM dd, yyyy")</span>
                    }
                    else
                    {
                        <span class="text-muted">Not provided</span>
                    }
                </div>
            }

            <!-- show for everyone -->
            <div class="row">
                <span class="label">Gender :</span>
                @if (Model.UserGender.HasValue)
                {
                    <span>@Model.UserGender</span>
                }
                else
                {
                    <span class="text-muted">Not provided</span>
                }
            </div>

            <div class="row">
                <span class="label">Bio :</span>
                @if (!string.IsNullOrWhiteSpace(Model.Bio))
                {
                    <span>@Model.Bio</span>
                }
                else
                {
                    <span class="text-muted">Not provided</span>
                }
            </div>

            <div class="row">
                <span class="label">Member Since :</span>
                <span>@Model.CreatedAt.ToString("MMMM dd, yyyy")</span>
            </div>

            <div class="row">
                <span class="label">Boards Created :</span>
                <span>@Model.BoardsCreatedCount</span>
            </div>

            <div class="row">
                <span class="label">Board Participations :</span>
                <span>@Model.BoardParticipationsCount</span>
            </div>
        </div>
        
        <!-- show for yourself -->
        @if (Model.IsOwnProfile)
        {
            <div class="divider">
                <button> class="large-button" href="@Url.Action("ChangePassword", "Account")">Reset Password</button>

                <form asp-action="SignOut" asp-controller="Account" method="post" style="display: inline;">
                    <button type="submit" class="large-button" style="border: none; background: none; padding: 0;">Sign Out</button>
                </form>
            </div>
        }
    </div>
</div>
